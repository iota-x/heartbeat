# heartbeat ingest — all optional. keyless default is PublicNode, which
# serves blockSubscribe for free: full live mode, zero credits, ~1min
# behind the chain head (auto-resubscribes if it drifts past ~2min).

# optional latency upgrade: Helius trades the ~1min lag for ~3s, but the
# free tier meters credits (getBlock polling ≈ 1 credit per block)
#HELIUS_API_KEY=

# any other RPC websocket; blockSubscribe used when available
#SOLANA_WS_URL=wss://solana-rpc.publicnode.com

# downstream websocket port for browsers
#PORT=8787

# transfers/swaps at or above this many SOL are flagged as whales
#WHALE_SOL=1000

# individual (non-vote) txs serialized per slot; whales always included
#MAX_TXS_PER_SLOT=150
