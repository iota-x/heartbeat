# heartbeat ingest — all optional; runs keyless against the public RPC by
# default (which refuses blockSubscribe → degraded slots-only mode, the
# client then falls back to its synthetic feed).

# recommended: full block stream via Helius (free tier works)
#HELIUS_API_KEY=

# any RPC websocket that has --rpc-pubsub-enable-block-subscription
#SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# downstream websocket port for browsers
#PORT=8787

# transfers/swaps at or above this many SOL are flagged as whales
#WHALE_SOL=1000

# individual (non-vote) txs serialized per slot; whales always included
#MAX_TXS_PER_SLOT=150
